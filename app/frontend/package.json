{
  "name": "specodex-frontend",
  "version": "1.0.0",
  "description": "Frontend for Specodex web application",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
